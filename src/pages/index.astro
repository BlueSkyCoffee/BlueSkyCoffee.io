---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroPanel from '../components/HeroPanel.astro';
import AboutPanel from '../components/AboutPanel.astro';
import PostsPanel from '../components/PostsPanel.astro';
import ContactPanel from '../components/ContactPanel.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="BlueSkyCoffee — 1bit Blog">
  <canvas class="bg-dither" id="bgDither"></canvas>
  <Header />

  <div class="scroll-wrapper">
    <div class="scroll-container" id="scrollContainer">
      <div class="scroll-track">
        <HeroPanel />
        <AboutPanel />
        <PostsPanel />
        <ContactPanel />
        <Footer />
      </div>
    </div>
  </div>

  <div class="scroll-progress">
    <div class="scroll-progress-bar" id="scrollProgressBar"></div>
  </div>
</BaseLayout>

<script type="module">
  import { initHorizontalScroll } from '../scripts/horizontal-scroll';
  import { initBackgroundDither } from '../scripts/background-dither';
  initHorizontalScroll();
  initBackgroundDither();
</script>
