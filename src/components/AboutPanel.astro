---
---

<section class="panel" id="about">
  <div class="panel-inner">
    <div class="section-header">
      <span class="section-number">01</span>
      <h2 class="section-title">ABOUT</h2>
      <div class="section-line"></div>
      <span class="section-tag">[profile]</span>
    </div>

    <div class="about-content">
      <div class="about-avatar-col">
        <div class="about-avatar">
          <div class="avatar-pixel-grid"></div>
          <div class="avatar-dither"></div>
          <div class="avatar-corner tl"></div>
          <div class="avatar-corner tr"></div>
          <div class="avatar-corner bl"></div>
          <div class="avatar-corner br"></div>
        </div>
        <div class="avatar-label">
          <span class="name">BlueSkyCoffee</span>
          <span class="role">Developer · Writer</span>
        </div>
      </div>

      <div class="about-info">
        <div class="about-bio">
          <p>Hi, I'm <strong>BlueSkyCoffee</strong>.</p>
          <p>I write code and thoughts in black &amp; white. <em>No gradients. No blur. Just pixels and ideas.</em></p>
          <p>Building things for the web since 2015. Believer in constraints as a creative tool.</p>
        </div>

        <div class="about-stats">
          <div class="stat-box">
            <span class="stat-num">47</span>
            <span class="stat-label">Articles</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">128</span>
            <span class="stat-label">Commits</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">11</span>
            <span class="stat-label">Projects</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">2K+</span>
            <span class="stat-label">Cups ☕</span>
          </div>
        </div>

        <div class="skills-section">
          <div class="skills-header">Skills &amp; Tools</div>
          <div class="skill-row">
            <span class="skill-name">JavaScript</span>
            <div class="skill-bar-container"><div class="skill-bar-fill" style="width: 90%"></div></div>
            <span class="skill-percent">90%</span>
          </div>
          <div class="skill-row">
            <span class="skill-name">React</span>
            <div class="skill-bar-container"><div class="skill-bar-fill" style="width: 85%"></div></div>
            <span class="skill-percent">85%</span>
          </div>
          <div class="skill-row">
            <span class="skill-name">Node.js</span>
            <div class="skill-bar-container"><div class="skill-bar-fill" style="width: 80%"></div></div>
            <span class="skill-percent">80%</span>
          </div>
          <div class="skill-row">
            <span class="skill-name">CSS/Design</span>
            <div class="skill-bar-container"><div class="skill-bar-fill" style="width: 88%"></div></div>
            <span class="skill-percent">88%</span>
          </div>
          <div class="skill-row">
            <span class="skill-name">Rust</span>
            <div class="skill-bar-container"><div class="skill-bar-fill" style="width: 45%"></div></div>
            <span class="skill-percent">45%</span>
          </div>
          <div class="skill-row">
            <span class="skill-name">Writing</span>
            <div class="skill-bar-container"><div class="skill-bar-fill" style="width: 92%"></div></div>
            <span class="skill-percent">92%</span>
          </div>
        </div>

        <div class="about-timeline-trigger">
          <button class="timeline-toggle-btn" id="timelineToggleBtn" type="button">
            <span class="btn-icon">▸</span>
            <span class="btn-label">TIMELINE</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  import { initTimeline } from '../scripts/timeline-overlay';
  initTimeline();
</script>
