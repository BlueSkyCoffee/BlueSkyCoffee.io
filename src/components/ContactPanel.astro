<section class="panel" id="contact">
  <div class="panel-inner">
    <div class="section-header">
      <span class="section-number">03</span>
      <h2 class="section-title">CONTACT</h2>
      <div class="section-line"></div>
    </div>

    <div class="contact-content">
      <div class="contact-visual">
        <div class="signal-tower">
          <div class="signal-wave"></div>
          <div class="signal-wave"></div>
          <div class="signal-wave"></div>
          <div class="tower-tip"></div>
          <div class="tower-body"></div>
          <div class="tower-base"></div>
          <div class="tower-ground"></div>
        </div>
      </div>

      <div class="contact-info">
        <div class="contact-card">
          <div class="card-label">Email</div>
          <div class="card-value">
            <a href="mailto:hello@blueskycoffee.dev">hello@blueskycoffee.dev</a>
          </div>
          <div class="card-dither"></div>
        </div>

        <div class="contact-card">
          <div class="card-label">Location</div>
          <div class="card-value">Internet — Available Worldwide</div>
          <div class="card-dither"></div>
        </div>
      </div>
    </div>
  </div>
</section>
